= Table.ReplaceValue(#"Reemplazado <3", ">8", "8.1", Replacer.ReplaceText, {"velocidad_laminacion_mps"})

// 2. Limpiar fuerza (quitar puntos)
= Table.TransformColumns(#"Reemplazado velocidad", {{"fuerza_rodillos_ton", each Text.Replace(_, ".", ""), type text}})

