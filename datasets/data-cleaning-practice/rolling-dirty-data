## Solución Rápida con Pandas (Ejemplo)

```python
import pandas as pd
import re

# Cargar datos
df = pd.read_csv('dataset_laminacion_acero_sucio.csv')

# 1. Limpiar IDs
df['id_lote'] = df['id_lote'].str.upper().str.replace(' ', '-')
df['id_lote'] = df['id_lote'].apply(lambda x: f"ACERO-{re.search(r'\d+', x).group()}" if re.search(r'\d+', x) else x)

# 2. Estandarizar turnos
mapeo_turnos = {
    'MANANA': 'Mañana', 'MAÑANA': 'Mañana', 'M': 'Mañana', 'mañana': 'Mañana',
    'TARDE': 'Tarde', 'T': 'Tarde', 'tarde': 'Tarde',
    'NOCHE': 'Noche', 'N': 'Noche', 'noche': 'Noche'
}
df['turno'] = df['turno'].replace(mapeo_turnos)

# 3. Limpiar fuerza (quitar puntos)
df['fuerza_rodillos_ton'] = df['fuerza_rodillos_ton'].astype(str).str.replace('.', '').str.replace(',', '')

# 4. Filtrar valores válidos
df_limpio = df[
    (df['espesor_entrada_mm'].between(150, 250)) &
    (df['espesor_salida_mm'].between(10, 50)) &
    (df['temperatura_laminacion_c'].between(900, 1200))
].copy()}

