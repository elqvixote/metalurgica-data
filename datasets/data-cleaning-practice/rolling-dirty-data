    {"espesor_entrada_mm", type number},
    {"velocidad_laminacion_mps", type number}
})

// 4. Filtrar valores válidos
= Table.SelectRows(#"Convertido a números", each [temperatura_laminacion_c] >= 900 and [temperatura_laminacion_c] <= 1200)

// 5. Agrupar por turno
= Table.Group(#"Filtrado", {"turno"}, {
    {"Promedio Temperatura", each List.Average([temperatura_laminacion_c]), type number},
    {"Total Defectos", each List.Count(List.Select([defectos], each _ <> "ok")), type number}
})


